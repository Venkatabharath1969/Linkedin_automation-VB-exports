# VB Exports Automation — Environment Variables
# Copy this file to .env and fill in your values for local development.
# For GitHub Actions, add each key as a Repository Secret.

# ── AI ─────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here                    # aistudio.google.com

# ── LinkedIn ────────────────────────────────────────────────────────────────
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here      # developer.linkedin.com
LINKEDIN_PERSON_URN=urn:li:person:YOUR_ID_HERE             # from /v2/userinfo
LINKEDIN_ORG_URN=urn:li:organization:YOUR_ORG_ID           # company page URN (optional)

# ── Facebook / Instagram (Meta) ─────────────────────────────────────────────
FACEBOOK_PAGE_ID=your_facebook_page_id_here                # Facebook Page ID
FACEBOOK_ACCESS_TOKEN=your_facebook_page_access_token      # Long-lived page token
INSTAGRAM_USER_ID=your_instagram_business_account_id       # IG Business Account ID

# ── Cloudinary (Instagram image hosting) ────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ── Google Sheets (Topic Queue) ─────────────────────────────────────────────
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_SHEETS_CREDS={"type":"service_account","project_id":"..."}  # Full JSON on one line

# ── Data APIs ───────────────────────────────────────────────────────────────
DATA_GOV_API_KEY=your_data_gov_in_api_key                  # data.gov.in (free)
GNEWS_API_KEY=your_gnews_api_key                           # gnews.io (free, 100/day)

# ── GitHub (for token auto-refresh — optional) ──────────────────────────────
GITHUB_TOKEN=your_github_pat_here
GITHUB_REPO=your_username/vb-exports-automation
